# ============================================
# PaisaGuru AI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================

# --- MongoDB Atlas (FREE Tier) ---
# 1. Go to https://cloud.mongodb.com
# 2. Create free account → Build a Cluster (M0 Free)
# 3. Database Access → Add user (username + password)
# 4. Network Access → Allow from anywhere (0.0.0.0/0)
# 5. Cluster → Connect → Drivers → Copy connection string
# 6. Replace <username>, <password>, and <dbname> below
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/paisaguru?retryWrites=true&w=majority

# --- Google Gemini API (FREE Tier) ---
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API Key"
# 3. Copy the key below
GEMINI_API_KEY=your-gemini-api-key-here

# --- Admin Panel ---
# Password to access /admin dashboard
ADMIN_PASSWORD=paisaguru2025

# --- Brevo SMTP (FREE Tier - Email Delivery) ---
# 1. Go to https://www.brevo.com → Sign up free
# 2. Settings → SMTP & API → SMTP tab
# 3. Copy host, port, login, and master password
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-login
BREVO_SMTP_PASS=your-brevo-smtp-master-password
BREVO_FROM_EMAIL=noreply@paisaguru.com
BREVO_FROM_NAME=PaisaGuru AI

# --- Cron Job Protection ---
# Secret token to protect automated endpoints (/api/cron/*)
# Generate your own: node -e "console.log('pgcron_'+require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=your-cron-secret-here

# --- Site Config ---
# For local testing, use http://localhost:3000
# Update to your actual domain when deployed
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Create a Disqus account at https://disqus.com when ready
# Leave as-is for now - comments section will show a placeholder
NEXT_PUBLIC_DISQUS_SHORTNAME=paisaguru
